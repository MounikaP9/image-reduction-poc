{
  "uid": "ol9-image-factory",
  "title": "OL9 Layered Image Factory Demo",
  "tags": [
    "ol9",
    "image-factory",
    "oci"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Current Step",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "image_factory_current_step",
          "legendFormat": "current",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "-1": {
                  "text": "Not Run"
                },
                "0": {
                  "text": "Completed"
                },
                "1": {
                  "text": "Simulate"
                },
                "2": {
                  "text": "Split"
                },
                "3": {
                  "text": "Deploy"
                },
                "4": {
                  "text": "Validate"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "gray",
                "value": null
              },
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "blue",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Validation",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "image_factory_validation_success",
          "legendFormat": "validation",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "-1": {
                  "text": "Not Run"
                },
                "0": {
                  "text": "Failed"
                },
                "1": {
                  "text": "Passed"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "gray",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Original Image Size",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "image_factory_artifact_size_bytes{artifact=\"original-simulated-image\"}",
          "legendFormat": "original-size",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Lifecycle Step Status",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "image_factory_step_status{step=\"simulate-image\"}",
          "legendFormat": "simulate",
          "refId": "A"
        },
        {
          "expr": "image_factory_step_status{step=\"split-layers\"}",
          "legendFormat": "split",
          "refId": "B"
        },
        {
          "expr": "image_factory_step_status{step=\"combine-layers\"}",
          "legendFormat": "deploy",
          "refId": "C"
        },
        {
          "expr": "image_factory_step_status{step=\"validate-image\"}",
          "legendFormat": "validate",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": -1,
          "max": 1,
          "mappings": [
            {
              "type": "value",
              "options": {
                "-1": {
                  "text": "Idle"
                },
                "0": {
                  "text": "Failed"
                },
                "0.5": {
                  "text": "Running"
                },
                "1": {
                  "text": "Success"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "gray",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "minVizWidth": 0,
        "minVizHeight": 10,
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Artifact Sizes",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "image_factory_artifact_size_bytes{artifact=\"original-simulated-image\"}",
          "legendFormat": "original-size",
          "refId": "A"
        },
        {
          "expr": "image_factory_artifact_size_bytes{artifact=\"layer-base\"}",
          "legendFormat": "layer-base",
          "refId": "B"
        },
        {
          "expr": "image_factory_artifact_size_bytes{artifact=\"layer-platform\"}",
          "legendFormat": "layer-platform",
          "refId": "C"
        },
        {
          "expr": "image_factory_artifact_size_bytes{artifact=\"mounted-output-image\"}",
          "legendFormat": "mounted",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "minVizWidth": 0,
        "minVizHeight": 10,
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    }
  ],
  "time": {
    "from": "now-30m",
    "to": "now"
  }
}